{
    "compilerOptions": {
      "target": "ES2022",                          
      "module": "commonjs",                        
      "rootDir": "./src",                         
      "outDir": "./dist",                         
      "strict": true,                              
      "esModuleInterop": true, 
      "noImplicitReturns": true,                    
      "skipLibCheck": true,                        
      "forceConsistentCasingInFileNames": true     
    },
    "include": ["src/**/*"]                       
  }